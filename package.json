{
  "name": "react-example",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && tsc --project tsconfig.server.json",
    "preview": "vite preview",
    "start": "node dist/server/server.js",
